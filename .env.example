# Copy to .env and fill in. Docker Compose auto-loads this file for ${...}
# substitution. The Hudu SDK is vendored in-repo, so no build-time token is needed.

# --- Hudu credentials (runtime, required) ---
HUDU_BASE_URL=https://your-instance.huducloud.com
HUDU_API_KEY=your-api-key

# --- Access control (optional) ---
# Comma-separated company IDs to hide from every tool and resource. The server
# behaves as if these companies — and their assets, articles, websites, and
# passwords — do not exist. Leave empty to disable.
HUDU_DISALLOWED_COMPANY_IDS=123,456

# --- Transport (optional; docker-compose.yml already sets these for HTTP) ---
# MCP_TRANSPORT=http
# MCP_HTTP_PORT=8080
# MCP_HTTP_HOST=0.0.0.0
# AUTH_MODE=env

# --- Logging (optional) ---
LOG_LEVEL=info
LOG_FORMAT=json
